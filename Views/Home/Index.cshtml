                            <span class="flex items-center gap-1.5">
                                <span class="w-3.5 h-3.5 rounded bg-red-100 inline-block"></span> Obsazeno
                            </span>
                        </div>
                    </div>

                    <!-- Počet osob -->
                    <div class="flex items-center gap-4">
                        <p class="text-stone-500 text-xs font-bold uppercase tracking-widest w-24">Osoby</p>
                        <div class="flex items-center gap-3 border-2 border-stone-200 rounded-xl px-4 py-2.5">
