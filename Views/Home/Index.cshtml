@section Scripts {
<script>
function heroSlider() {
    return {
        current: 0,
        slides: [
            { img: '/images/HotelKarl-1.jpg', alt: 'Hotel Karl léto',    badge: 'Špičák · Železná Ruda · Šumava · 1000 m n.m.' },
            { img: '/images/HotelKarl-2.jpg', alt: 'Hotel Karl zima',    badge: '❄️ Lyžování přímo od hotelu' },
            { img: 'https://images.unsplash.com/photo-1551698618-1dfe5d97d256?w=1600&q=80', alt: 'Sjezdovky Špičák',     badge: '⛷️ Ski areál Špičák – přímo u dveří' },
            { img: 'https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=1600&q=80', alt: 'Šumavská příroda', badge: '🥾 Turistika – Černé jezero 3,5 km' },
        ],
        init() {
            setInterval(() => { this.current = (this.current + 1) % this.slides.length; }, 5000);
        },
        goTo(i) { this.current = i; }
    };
}

function rezervace() {
    return {
        step: 1,
        od: '',
        doDate: '',
        osoby: 2,
        pokoj: '',
        calYear: new Date().getFullYear(),
        calMonth: new Date().getMonth(),
        pokoje: [
            { id: 'Apartmá 2 ložnice', icon: '🏠', label: 'Apartmá 2 ložnice', popis: 'Až 6 os., balkon, obýv. pokoj', cena: 'od 1 190 Kč/os/noc', ppn: 1190, max: 6 },
            { id: 'Apartmá 1 ložnice', icon: '🛏️', label: 'Apartmá 1 ložnice', popis: '2–4 os., ložnice + obývák',      cena: 'od 1 190 Kč/os/noc', ppn: 1190, max: 4 },
            { id: 'Dvoulůžkový pokoj', icon: '🛌', label: 'Dvoulůžkový pokoj', popis: '2 os., ložnice + koupelna',       cena: 'od 1 390 Kč/os/noc', ppn: 1390, max: 2 },
        ],
        get nights() {
            if (!this.od || !this.doDate) return 0;
            const n = Math.round((new Date(this.doDate) - new Date(this.od)) / 86400000);
            return n > 0 ? n : 0;
        },
        get selectedPokoj() {
            return this.pokoje.find(p => p.id === this.pokoj) || null;
        },
        get totalPrice() {
            const p = this.selectedPokoj;
            if (!p || this.nights <= 0) return 0;
            const ppn = this.nights === 1 ? p.ppn * 2 : p.ppn;
            return ppn * this.osoby * this.nights;
        },
        get busySet() {
            const ranges = [
                ['2026-06-06','2026-06-08'], ['2026-06-13','2026-06-15'],
                ['2026-06-27','2026-07-05'], ['2026-07-11','2026-07-13'],
                ['2026-07-18','2026-07-27'], ['2026-08-01','2026-08-17'],
            ];
            const s = new Set();
            for (const [a, b] of ranges) {
                for (let d = new Date(a); d <= new Date(b); d.setDate(d.getDate()+1))
                    s.add(d.toISOString().slice(0,10));
            }
            return s;
        },
        get calMonthLabel() {
            return new Date(this.calYear, this.calMonth, 1)
                .toLocaleDateString('cs-CZ', { month: 'long', year: 'numeric' });
        },
        get calDays() {
            const y = this.calYear, m = this.calMonth;
            const first = new Date(y, m, 1);
            const last  = new Date(y, m+1, 0);
            const today = new Date(); today.setHours(0,0,0,0);
            let dow = first.getDay(); dow = dow === 0 ? 6 : dow - 1;
            const days = [];
            for (let i = 0; i < dow; i++)
                days.push({ key: 'e'+i, inMonth: false, d: '', str: '', isPast: false, isBusy: false, isStart: false, isEnd: false, inRange: false, disabled: true });
            for (let d = 1; d <= last.getDate(); d++) {
                const date = new Date(y, m, d);
                const str  = date.toISOString().slice(0,10);
                const isPast = date < today;
                const isBusy = !isPast && this.busySet.has(str);
                const isStart = str === this.od;
                const isEnd   = str === this.doDate;
                const inRange = !!(this.od && this.doDate && str > this.od && str < this.doDate);
                days.push({ key: str, inMonth: true, d, str, isPast, isBusy, isStart, isEnd, inRange, disabled: isPast || isBusy });
            }
            return days;
        },
        prevCal() {
            if (this.calMonth === 0) { this.calMonth = 11; this.calYear--; }
            else this.calMonth--;
        },
        nextCal() {
            if (this.calMonth === 11) { this.calMonth = 0; this.calYear++; }
            else this.calMonth++;
        },
        selectDay(str) {
            if (!this.od || this.doDate || str <= this.od) {
                this.od = str; this.doDate = '';
            } else {
                // Reject range if it spans a busy date
                let hasBusy = false;
                for (let d = new Date(this.od); d < new Date(str); d.setDate(d.getDate()+1))
                    if (this.busySet.has(d.toISOString().slice(0,10))) { hasBusy = true; break; }
                if (hasBusy) { this.od = str; this.doDate = ''; }
                else this.doDate = str;
            }
        },
        fmtDate(str) {
            if (!str) return '';
            const [y,m,d] = str.split('-');
            return d + '.' + m + '.';
        },
        step2() {
            if (!this.pokoj || !this.od || !this.doDate || this.nights <= 0) return;
            this.step = 2;
        },
        init() {
            this.$watch('pokoj', id => {
                const p = this.pokoje.find(x => x.id === id);
                if (p && this.osoby > p.max) this.osoby = p.max;
            });
        }
    };
}
</script>
}

