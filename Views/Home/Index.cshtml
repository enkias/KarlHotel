                        </div>
                        <p x-show="selectedPokoj" class="text-xs text-stone-400"
                           x-text="'max. ' + (selectedPokoj ? selectedPokoj.max : '') + ' os.'"></p>
                    </div>

                    <!-- Cenový souhrn -->
                    <div x-show="nights > 0 && pokoj" class="bg-stone-50 rounded-2xl p-5 flex items-center justify-between">
                        <div class="text-sm text-stone-500">
                            <span x-text="pokoj"></span> · <span x-text="nights"></span> <span x-text="nights === 1 ? 'noc' : nights < 5 ? 'noci' : 'nocí'"></span> · <span x-text="osoby"></span> <span x-text="osoby === 1 ? 'osoba' : osoby < 5 ? 'osoby' : 'osob'"></span>
                        </div>
                        <div class="text-right">
                            <div class="text-xs text-stone-400">Orientační cena</div>
                            <div class="text-forest-700 font-bold text-xl" x-text="totalPrice.toLocaleString('cs-CZ') + ' Kč'"></div>
                        </div>
                    </div>

                    <button type="button"
                            x-on:click="step2()"
                            :disabled="!pokoj || !od || !doDate || nights <= 0"
                            class="w-full bg-forest-600 hover:bg-forest-500 disabled:opacity-40 disabled:cursor-not-allowed text-white font-bold py-4 rounded-2xl text-base transition-all">
                        Pokračovat k údajům →
                    </button>
                </div>

                <!-- KROK 2 -->
                <div x-show="step === 2" class="p-8">
                    <!-- Shrnutí nahoře -->
                    <div class="bg-forest-50 border border-forest-200 rounded-2xl p-4 mb-6 flex items-center justify-between text-sm">
                        <div class="text-stone-600">
                            <strong class="text-stone-900" x-text="pokoj"></strong>
                            · <span x-text="od"></span> → <span x-text="doDate"></span>
                            · <span x-text="osoby + ' os.'"></span>
                        </div>
                        <div class="font-bold text-forest-700" x-text="totalPrice.toLocaleString('cs-CZ') + ' Kč'"></div>
                    </div>

                    <div class="grid sm:grid-cols-2 gap-5">
                        <div>
                            <label class="text-stone-500 text-xs font-bold uppercase tracking-widest block mb-2">Jméno a příjmení *</label>
                            <input name="Jmeno" required type="text" placeholder="Jan Novák"
                                   class="w-full border-2 border-stone-200 focus:border-forest-500 rounded-xl px-4 py-3 text-stone-900 text-sm focus:outline-none transition-colors" />
                        </div>
                        <div>
                            <label class="text-stone-500 text-xs font-bold uppercase tracking-widest block mb-2">E-mail *</label>
                            <input name="Email" required type="email" placeholder="jan@email.cz"
                                   class="w-full border-2 border-stone-200 focus:border-forest-500 rounded-xl px-4 py-3 text-stone-900 text-sm focus:outline-none transition-colors" />
                        </div>
                        <div>
                            <label class="text-stone-500 text-xs font-bold uppercase tracking-widest block mb-2">Telefon</label>
                            <input name="Telefon" type="tel" placeholder="+420 123 456 789"
                                   class="w-full border-2 border-stone-200 focus:border-forest-500 rounded-xl px-4 py-3 text-stone-900 text-sm focus:outline-none transition-colors" />
                        </div>
                        <div>
                            <label class="text-stone-500 text-xs font-bold uppercase tracking-widest block mb-2">Domácí zvíře?</label>
                            <select name="Poznamka"
                                    class="w-full border-2 border-stone-200 focus:border-forest-500 rounded-xl px-4 py-3 text-stone-900 text-sm focus:outline-none transition-colors bg-white">
                                <option value="">Ne</option>
                                <option value="Cestuji s domácím zvířetem (100 Kč/den)">Ano (+100 Kč/den)</option>
                            </select>
                        </div>
                    </div>

                    <div class="mt-5">
                        <label class="text-stone-500 text-xs font-bold uppercase tracking-widest block mb-2">Poznámka / přání</label>
                        <textarea name="Poznamka2" rows="2" placeholder="Dětská postýlka, garáž, příjezd v pozdních hodinách…"
                                  class="w-full border-2 border-stone-200 focus:border-forest-500 rounded-xl px-4 py-3 text-stone-900 text-sm focus:outline-none transition-colors resize-none"></textarea>
                    </div>

                    <div class="flex gap-3 mt-6">
                        <button type="button" x-on:click="step = 1"
                                class="px-6 border-2 border-stone-200 hover:border-stone-400 text-stone-600 font-semibold rounded-2xl py-4 transition-colors text-sm">
                            ← Zpět
                        </button>
                        <button type="submit"
                                class="flex-1 bg-forest-600 hover:bg-forest-500 text-white font-bold py-4 rounded-2xl text-base transition-all">
                            Odeslat poptávku →
                        </button>
                    </div>
                    <p class="text-center text-stone-400 text-xs mt-4">Potvrzení do 24 hodin. Žádný závazek k platbě.</p>
                </div>
            </form>
        </div>
    </div>
</section>

