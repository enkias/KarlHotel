@{
    ViewData["Title"] = "Hotel Karl Špičák – Ubytování na Šumavě";
    ViewData["Description"] = "Rodinný hotel Karl na Špičáku, Železná Ruda – Šumava. Ubytování s snídaní, restaurace, lyžování, turistika. Rezervujte přímo – nejlepší cena zaručena.";
}

<!-- HERO -->
<section x-data="heroSlider()" class="relative min-h-screen flex items-end overflow-hidden">

    <!-- Slides -->
    <template x-for="(s, i) in slides" :key="i">
        <img :src="s.img" :alt="s.alt"
             x-show="current === i"
             x-transition:enter="transition-opacity duration-1000"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             x-transition:leave="transition-opacity duration-1000"
             x-transition:leave-start="opacity-100"
             x-transition:leave-end="opacity-0"
             class="absolute inset-0 w-full h-full object-cover" />
    </template>
    <div class="absolute inset-0 bg-gradient-to-t from-stone-900/80 via-stone-900/30 to-transparent"></div>

    <!-- Navbar -->
    <nav class="absolute top-0 left-0 right-0 z-20 px-6 py-5">
        <div class="max-w-6xl mx-auto flex items-center justify-between">
            <a href="/" class="text-white font-display text-2xl font-bold tracking-wide">Hotel Karl <span class="text-forest-400">★★★</span></a>
            <div class="hidden md:flex items-center gap-8 text-sm text-white/80 font-medium">
                <a href="#pokoje" class="hover:text-white transition-colors">Pokoje</a>
                <a href="/restaurace" class="hover:text-white transition-colors">Restaurace</a>
                <a href="/vylety" class="hover:text-white transition-colors">Výlety</a>
                <a href="/galerie" class="hover:text-white transition-colors">Galerie</a>
                <a href="#kontakt" class="hover:text-white transition-colors">Kontakt</a>
                <a href="#rezervace" class="bg-forest-600 hover:bg-forest-500 text-white px-5 py-2 rounded-full transition-colors font-semibold">Rezervovat přímo</a>
            </div>
        </div>
    </nav>

    <div class="relative z-10 max-w-6xl mx-auto px-6 pb-24 w-full">
        <div class="max-w-2xl">
            <span class="inline-block bg-forest-500/20 text-forest-300 text-xs font-semibold px-4 py-2 rounded-full mb-6 backdrop-blur-sm border border-forest-500/30"
                  x-text="slides[current].badge"></span>
            <h1 class="font-display text-5xl sm:text-6xl font-bold text-white leading-tight mb-6">
                Váš rodinný hotel<br/>v srdci Šumavy
            </h1>
            <p class="text-stone-300 text-lg leading-relaxed mb-10">
                Ideální základna pro lyžování, cyklistiku i pěší turistiku. Čisté horské prostředí, restaurace a rodinná atmosféra od roku 2001.
            </p>
            <div class="flex flex-wrap gap-4">
                <a href="#rezervace"
                   class="bg-forest-600 hover:bg-forest-500 text-white font-bold px-8 py-4 rounded-full text-lg transition-all hover:shadow-xl hover:shadow-forest-900/40">
                    Rezervovat přímo →
                </a>
                <a href="#pokoje"
                   class="bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white font-semibold px-8 py-4 rounded-full text-lg transition-all border border-white/20">
                    Zobrazit pokoje
                </a>
            </div>
        </div>
    </div>

    <!-- Slide dots -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-2 z-20">
        <template x-for="(s, i) in slides" :key="i">
            <button x-on:click="goTo(i)"
                    :class="current === i ? 'w-6 bg-white' : 'w-2 bg-white/50'"
                    class="h-2 rounded-full transition-all duration-300"></button>
        </template>
    </div>
</section>

<!-- PROČ REZERVOVAT PŘÍMO -->
<section class="bg-forest-800 py-14">
    <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-10 items-center">
            <div>
                <span class="text-forest-400 text-xs font-bold uppercase tracking-widest">Přímá rezervace</span>
                <h2 class="font-display text-3xl font-bold text-white mt-3 mb-4">Rezervujte přímo.<br/>Jsme tu pro vás osobně.</h2>
                <p class="text-stone-300 leading-relaxed mb-6">
                    Přímou rezervací získáte osobní přístup, flexibilitu a přímý kontakt s hotelem – bez prostředníků.
                </p>
                <ul class="space-y-3 mb-8">
                    @foreach (var item in new[] {
                        "Bezplatné storno do 7 dní před příjezdem",
                        "Osobní potvrzení do 24 hodin",
                        "Speciální přání zohledníme předem",
                        "Přímý kontakt s rodinou na recepci"
                    })
                    {
                        <li class="flex items-center gap-3 text-stone-300 text-sm">
                            <svg class="w-5 h-5 text-forest-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                            @item
                        </li>
                    }
                </ul>
                <a href="#rezervace"
                   class="inline-block bg-forest-500 hover:bg-forest-400 text-white font-bold px-8 py-4 rounded-full transition-all hover:shadow-xl hover:shadow-forest-900/40">
                    Přejít na rezervační formulář →
                </a>
            </div>
            <!-- Rychlý kontakt -->
            <div class="bg-white/10 backdrop-blur-sm rounded-3xl p-8 border border-white/10 space-y-6">
                <p class="text-forest-300 text-xs font-bold uppercase tracking-widest">Nebo nás kontaktujte přímo</p>
                <a href="tel:+420739015629" class="flex items-center gap-4 group">
                    <div class="w-12 h-12 bg-forest-600 rounded-2xl flex items-center justify-center group-hover:bg-forest-500 transition-colors">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    </div>
                    <div>
                        <p class="text-xs text-stone-400">Recepce (ihned)</p>
                        <p class="text-white font-bold text-lg group-hover:text-forest-300 transition-colors">+420 739 015 629</p>
                    </div>
                </a>
                <a href="mailto:hotelkarl@seznam.cz" class="flex items-center gap-4 group">
                    <div class="w-12 h-12 bg-forest-600 rounded-2xl flex items-center justify-center group-hover:bg-forest-500 transition-colors">
                        <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    </div>
                    <div>
                        <p class="text-xs text-stone-400">E-mail (do 24 hod)</p>
                        <p class="text-white font-bold group-hover:text-forest-300 transition-colors">hotelkarl@seznam.cz</p>
                    </div>
                </a>
                <div class="border-t border-white/10 pt-4">
                    <p class="text-stone-400 text-xs text-center">Odpovídáme každý den · i o víkendu</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- POKOJE -->
<section id="pokoje" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-14">
            <span class="text-forest-600 text-xs font-bold uppercase tracking-widest">Ubytování</span>
            <h2 class="font-display text-4xl font-bold text-stone-900 mt-2">14 pokojů ve třech kategoriích</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-8">
            @{
                var pokoje = new[] {
                    new { Img = "/images/pokoj-1.jpg", Nadpis = "Apartmá se 2 ložnicemi", Popis = "Prostorné apartmá pro rodiny – 2 ložnice (až 6 lůžek), velký obývací pokoj, koupelna s vanou i sprchou, balkon s výhledem do hor.", Cena = "od 1 190 Kč / os / noc", Badge = "Nejprostornější", Pocet = "1×" },
                    new { Img = "/images/pokoj-2.jpg", Nadpis = "Apartmá s 1 ložnicí", Popis = "Útulné apartmá pro páry nebo rodiny – ložnice, obývací pokoj, koupelna. Většina disponuje balkonem. Lednička, Wi-Fi.", Cena = "od 1 190 Kč / os / noc", Badge = "Nejoblíbenější", Pocet = "9×" },
                    new { Img = "/images/pokoj-3.jpg", Nadpis = "Dvoulůžkový pokoj", Popis = "Komfortní pokoj pro 2 osoby – ložnice s koupelnou, lednička, parkoviště zdarma. Ideální pro výletníky nebo lyžaře.", Cena = "od 1 390 Kč / os / noc", Badge = "Pro páry", Pocet = "4×" },
                };
            }
            @foreach (var p in pokoje)
            {
                <div class="group bg-white rounded-3xl overflow-hidden shadow-sm border border-stone-100 hover:shadow-xl transition-all duration-300">
                    <div class="relative overflow-hidden aspect-[4/3]">
                        <img src="@p.Img" alt="@p.Nadpis" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        <div class="absolute top-4 left-4">
                            <span class="bg-forest-600 text-white text-xs font-bold px-3 py-1.5 rounded-full">@p.Badge</span>
                        </div>
                        <div class="absolute top-4 right-4">
                            <span class="bg-black/50 text-white text-xs font-semibold px-3 py-1.5 rounded-full">@p.Pocet</span>
                        </div>
                    </div>
                    <div class="p-6">
                        <h3 class="font-display font-bold text-xl text-stone-900 mb-3">@p.Nadpis</h3>
                        <p class="text-stone-500 text-sm leading-relaxed mb-5">@p.Popis</p>
                        <div class="flex items-center justify-between">
                            <span class="text-forest-700 font-bold text-sm">@p.Cena</span>
                            <a href="#rezervace" class="text-xs font-semibold text-forest-600 hover:text-forest-500 transition-colors">Rezervovat →</a>
                        </div>
                    </div>
                </div>
            }
        </div>
        <p class="text-center text-stone-400 text-sm mt-6">Ceny platí pro pobyt od 2 nocí se snídaní. Děti 3–12 let 690 Kč/noc.</p>
    </div>
</section>

<!-- VYBAVENÍ -->
<section class="py-14 bg-stone-50 border-y border-stone-100">
    <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-10">
            <span class="text-forest-600 text-xs font-bold uppercase tracking-widest">Vybavení a služby</span>
            <h2 class="font-display text-3xl font-bold text-stone-900 mt-2">Co u nás najdete</h2>
        </div>

        <!-- Top highlights -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 mb-10">
            @{
                var highlights = new[] {
                    new { Icon = "🎿", Label = "Přímo u sjezdovky",   Sub = "Ski areál Špičák" },
                    new { Icon = "🚗", Label = "Parkování zdarma",    Sub = "Přímo v areálu" },
                    new { Icon = "🍳", Label = "Snídaně v ceně",      Sub = "Švédský stůl" },
                    new { Icon = "🐕", Label = "Domácí zvířata",      Sub = "100 Kč / den" },
                    new { Icon = "👨‍👩‍👧‍👦", Label = "Rodinné pokoje",     Sub = "Až 6 osob" },
                };
            }
            @foreach (var h in highlights)
            {
                <div class="bg-white rounded-2xl p-5 border border-stone-100 shadow-sm text-center">
                    <div class="text-3xl mb-2">@h.Icon</div>
                    <div class="font-semibold text-stone-900 text-sm">@h.Label</div>
                    <div class="text-xs text-stone-400 mt-0.5">@h.Sub</div>
                </div>
            }
        </div>

        <!-- Full amenity list -->
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-3">
            @{
                var amenities = new[] {
                    ("❄️", "Lednička na pokoji"),
                    ("🌿", "Terasa"),
                    ("🍽️", "Restaurace a snack bar"),
                    ("🚵", "Půjčení kola"),
                    ("🥾", "Pěší turistika"),
                    ("🧒", "Dětské hřiště"),
                    ("🍜", "Dětské menu na vyžádání"),
                    ("☀️", "Obědové balíčky"),
                    ("🗣️", "Personál: CS · DE · EN · ES · SK"),
                };
            }
            @foreach (var (icon, text) in amenities)
            {
                <div class="flex items-center gap-2.5 text-sm text-stone-600 py-1.5">
                    <span class="text-base flex-shrink-0">@icon</span>
                    <span>@text</span>
                </div>
            }
        </div>

        <p class="text-xs text-stone-400 mt-6 text-center">
            Wi-Fi v prostorách recepce · Garáž 200 Kč/den · Vyhrazený prostor pro kuřáky
        </p>
    </div>
</section>

<!-- RESTAURACE -->
<section id="restaurace" class="py-20 bg-stone-50">
    <div class="max-w-6xl mx-auto px-6">
        <div class="grid md:grid-cols-2 gap-16 items-center">
            <div class="relative">
                <img src="/images/snidane-1.jpg"
                     alt="Restaurace" class="rounded-3xl w-full aspect-[4/3] object-cover shadow-xl" />
                <div class="absolute -bottom-5 -right-5 bg-forest-600 text-white rounded-2xl px-6 py-4 shadow-lg">
                    <p class="text-xs font-semibold text-forest-200 mb-1">Otevírací doba</p>
                    <p class="font-bold">Čt – Ne</p>
                    <p class="text-sm text-forest-100">11:00 – 19:30</p>
                </div>
            </div>
            <div>
                <span class="text-forest-600 text-xs font-bold uppercase tracking-widest">Restaurace</span>
                <h2 class="font-display text-4xl font-bold text-stone-900 mt-2 mb-5">Domácí kuchyně s výhledem na Šumavu</h2>
                <p class="text-stone-600 leading-relaxed mb-6">
                    Naše restaurace nabízí tradiční českou kuchyni z lokálních surovin. Snídaně formou bohatého švédského stolu. Večeře pro ubytované hosty za 390 Kč.
                </p>
                <div class="grid grid-cols-2 gap-4">
                    @foreach (var f in new[] { "Švédský stůl ke snídani", "Večeře 390 Kč / dospělí", "Večeře 290 Kč / děti", "Objednávka na míru" })
                    {
                        <div class="flex items-center gap-2 text-sm text-stone-600">
                            <span class="w-2 h-2 bg-forest-500 rounded-full flex-shrink-0"></span>
                            @f
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- AKTIVITY -->
<section id="aktivity" class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-14">
            <span class="text-forest-600 text-xs font-bold uppercase tracking-widest">Celý rok</span>
            <h2 class="font-display text-4xl font-bold text-stone-900 mt-2">Co vás čeká na Šumavě</h2>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
            @{
                var aktivity = new[] {
                    new { Icon = "⛷️", Nazev = "Lyžování", Popis = "Lyžařský areál Špičák přímo u hotelu. Svahy pro všechny úrovně, vleky, snowpark.", Sezona = "Zima" },
                    new { Icon = "🚵", Nazev = "Bike areál", Popis = "6 bikerských tras světové úrovně. Každoroční konání Downhill World Cup.", Sezona = "Jaro – Podzim" },
                    new { Icon = "🥾", Nazev = "Turistika", Popis = "Černé jezero 3,5 km, Čertovo 2,5 km, vodopád Bílá strž 6 km, Pancíř, Špičák.", Sezona = "Celý rok" },
                    new { Icon = "🚡", Nazev = "Lanovka", Popis = "Lanovka na Špičák přímo od hotelu. Výhledy na Šumavu za každého počasí.", Sezona = "Celý rok" },
                };
            }
            @foreach (var a in aktivity)
            {
                <div class="bg-stone-50 rounded-3xl p-7 hover:bg-forest-50 hover:border-forest-200 border border-stone-100 transition-all">
                    <div class="text-4xl mb-4">@a.Icon</div>
                    <span class="text-forest-600 text-xs font-semibold">@a.Sezona</span>
                    <h3 class="font-bold text-stone-900 text-lg mt-1 mb-2">@a.Nazev</h3>
                    <p class="text-stone-500 text-sm leading-relaxed">@a.Popis</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- HODNOCENÍ -->
<section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-6">
        <!-- Badge -->
        <div class="flex flex-col sm:flex-row items-center justify-between gap-8 mb-14">
            <div>
                <span class="text-forest-600 text-xs font-bold uppercase tracking-widest">Hodnocení hostů</span>
                <h2 class="font-display text-4xl font-bold text-stone-900 mt-2">Co říkají naši hosté</h2>
            </div>
            <div class="flex gap-4">
                <div class="bg-forest-50 border border-forest-200 rounded-2xl px-7 py-5 text-center">
                    <div class="text-4xl font-bold text-forest-700">9,1</div>
                    <div class="text-sm font-bold text-forest-600 mt-0.5">Fantastické</div>
                    <div class="text-xs text-stone-400 mt-1">Booking.com · 214 recenzí</div>
                </div>
                <div class="bg-stone-50 border border-stone-200 rounded-2xl px-7 py-5 text-center">
                    <div class="text-4xl font-bold text-stone-700">4,2</div>
                    <div class="text-sm font-bold text-stone-600 mt-0.5">Velmi dobré</div>
                    <div class="text-xs text-stone-400 mt-1">Google · 45 recenzí</div>
                </div>
            </div>
        </div>

        <!-- Recenze -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
            @{
                var recenze = new[] {
                    new { Jmeno = "martinbartusek", Zeme = "🇨🇿", Hodnoceni = 5, Text = "Skvělá obsluha, jídlo moc dobré, parkování na místě za pár korun.", Pobyt = "Srpen 2025" },
                    new { Jmeno = "Markéta S.",      Zeme = "🇨🇿", Hodnoceni = 5, Text = "Perfektní poloha – ráno jsme vstali a byli jsme na sjezdovce. Děti nadšené. Snídaně výborná, švédský stůl přehlídky.", Pobyt = "Leden 2026" },
                    new { Jmeno = "Thomas K.",       Zeme = "🇩🇪", Hodnoceni = 5, Text = "Sehr freundliches Personal, saubere Zimmer und fantastischer Blick. Wir kommen wieder!", Pobyt = "Februar 2026" },
                    new { Jmeno = "Petra &amp; Jan", Zeme = "🇨🇿", Hodnoceni = 5, Text = "Rodinná atmosféra, klidné prostředí. Výlety k jezerům přímo z hotelu. Doporučujeme každému, kdo chce opravdu odpočinout.", Pobyt = "Říjen 2025" },
                };
            }
            @foreach (var r in recenze)
            {
                <div class="bg-stone-50 rounded-3xl p-6 border border-stone-100">
                    <div class="flex items-center gap-1 mb-3">
                        @for (int i = 0; i < r.Hodnoceni; i++) { <span class="text-amber-400 text-sm">★</span> }
                    </div>
                    <p class="text-stone-700 text-sm leading-relaxed mb-4">"@Html.Raw(r.Text)"</p>
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="font-semibold text-stone-900 text-sm">@r.Zeme @Html.Raw(r.Jmeno)</p>
                            <p class="text-stone-400 text-xs">@r.Pobyt</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- REZERVACE -->
<section id="rezervace" class="py-20 bg-forest-800">
    <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-10">
            <span class="text-forest-400 text-xs font-bold uppercase tracking-widest">Rezervace</span>
            <h2 class="font-display text-4xl font-bold text-white mt-2 mb-3">Poptávka ubytování</h2>
            <p class="text-stone-300">Odpovíme do 24 hodin s potvrzením dostupnosti.</p>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="bg-forest-600 text-white rounded-2xl px-6 py-4 mb-6 text-center font-semibold">
                ✓ @TempData["Success"]
            </div>
        }

        <div x-data="rezervace()" class="bg-white rounded-3xl shadow-2xl overflow-hidden">

            <!-- Step indikátor -->
            <div class="flex">
                <div x-on:click="step > 1 && (step = 1)"
                     :class="step === 1 ? 'bg-forest-700 text-white' : 'bg-forest-900 text-forest-300 cursor-pointer hover:bg-forest-800'"
                     class="flex-1 flex items-center justify-center gap-2 py-4 text-sm font-semibold transition-colors">
                    <span :class="step >= 1 ? 'bg-white/20' : 'bg-white/10'" class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold">1</span>
                    <span class="hidden sm:inline">Pobyt &amp; pokoj</span>
                </div>
                <div class="w-px bg-forest-600"></div>
                <div :class="step === 2 ? 'bg-forest-700 text-white' : 'bg-forest-900 text-forest-500'"
                     class="flex-1 flex items-center justify-center gap-2 py-4 text-sm font-semibold">
                    <span :class="step === 2 ? 'bg-white/20' : 'bg-white/10'" class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold">2</span>
                    <span class="hidden sm:inline">Vaše údaje</span>
                </div>
            </div>

            <form method="post" action="/rezervace">
                <input type="hidden" name="Od"        x-bind:value="od" />
                <input type="hidden" name="Do"        x-bind:value="doDate" />
                <input type="hidden" name="TypPokoje" x-bind:value="pokoj" />
                <input type="hidden" name="Osoby"     x-bind:value="osoby" />

                <!-- KROK 1 -->
                <div x-show="step === 1" class="p-8 space-y-6">

                    <!-- Výběr pokoje -->
                    <div>
                        <p class="text-stone-500 text-xs font-bold uppercase tracking-widest mb-3">Typ pokoje</p>
                        <div class="grid sm:grid-cols-3 gap-3">
                            <template x-for="p in pokoje" :key="p.id">
                                <button type="button"
                                        x-on:click="pokoj = p.id"
                                        :class="pokoj === p.id
                                            ? 'border-forest-600 bg-forest-50 ring-2 ring-forest-500'
                                            : 'border-stone-200 hover:border-forest-400'"
                                        class="border-2 rounded-2xl p-4 text-left transition-all">
                                    <div class="text-xl mb-1" x-text="p.icon"></div>
                                    <div class="font-semibold text-stone-900 text-sm" x-text="p.label"></div>
                                    <div class="text-xs text-stone-400 mt-0.5" x-text="p.popis"></div>
                                    <div class="text-forest-700 font-bold text-sm mt-2" x-text="p.cena"></div>
                                </button>
                            </template>
                        </div>
                    </div>

                    <!-- Kalendář termínu -->
                    <div>
                        <div class="flex items-center justify-between mb-1">
                            <p class="text-stone-500 text-xs font-bold uppercase tracking-widest">Termín pobytu</p>
                            <p class="text-xs text-forest-600 font-medium"
                               x-show="!od">Klikněte na datum příjezdu</p>
                            <p class="text-xs text-forest-600 font-medium"
                               x-show="od && !doDate">Teď vyberte odjezd</p>
                            <p class="text-xs text-stone-500"
                               x-show="od && doDate"
                               x-text="fmtDate(od) + ' → ' + fmtDate(doDate) + ' (' + nights + (nights===1?' noc':nights<5?' noci':' nocí') + ')'"></p>
                        </div>
                        <!-- Navigace měsíce -->
                        <div class="flex items-center justify-between mt-3 mb-2">
                            <button type="button" x-on:click="prevCal()"
                                    class="w-8 h-8 rounded-full hover:bg-stone-100 flex items-center justify-center text-stone-500 transition-colors text-lg leading-none">‹</button>
                            <span class="font-semibold text-stone-800 text-sm capitalize" x-text="calMonthLabel"></span>
                            <button type="button" x-on:click="nextCal()"
                                    class="w-8 h-8 rounded-full hover:bg-stone-100 flex items-center justify-center text-stone-500 transition-colors text-lg leading-none">›</button>
                        </div>
                        <!-- Hlavičky dní -->
                        <div class="grid grid-cols-7 text-center mb-1">
                            <template x-for="h in ['Po','Út','St','Čt','Pá','So','Ne']" :key="h">
                                <span class="text-xs text-stone-400 font-semibold py-1" x-text="h"></span>
                            </template>
                        </div>
                        <!-- Dny -->
                        <div class="grid grid-cols-7 gap-0.5">
                            <template x-for="day in calDays" :key="day.key">
                                <button type="button"
                                        x-on:click="day.inMonth && !day.disabled && selectDay(day.str)"
                                        :class="{
                                            'invisible': !day.inMonth,
                                            'text-stone-300 cursor-not-allowed': day.isPast,
                                            'bg-red-100 text-red-300 line-through cursor-not-allowed': day.isBusy,
                                            'bg-forest-700 !text-white font-bold rounded-full': day.isStart || day.isEnd,
                                            'bg-forest-100 text-forest-900 rounded-none': day.inRange,
                                            'rounded-l-full': day.isStart && !day.isEnd,
                                            'rounded-r-full': day.isEnd && !day.isStart,
                                            'hover:bg-stone-100': !day.disabled && !day.isStart && !day.isEnd && !day.inRange
                                        }"
                                        class="h-9 flex items-center justify-center text-sm transition-colors rounded-lg text-stone-700">
                                    <span x-text="day.d"></span>
                                </button>
                            </template>
                        </div>
                        <!-- Legenda -->
                        <div class="flex items-center gap-5 mt-3 text-xs text-stone-400">
                            <span class="flex items-center gap-1.5">
                                <span class="w-3.5 h-3.5 rounded-full bg-forest-700 inline-block"></span> Váš pobyt
