<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? "Hotel Karl Špičák – Šumava")</title>
    <meta name="description" content="@(ViewData["Description"] ?? "Rodinný hotel Karl na Špičáku, Železná Ruda – Šumava. Ubytování, restaurace, výlety. Rezervujte přímo a ušetřete.")" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        forest: { 50:'#f0fdf4',100:'#dcfce7',500:'#22c55e',600:'#16a34a',700:'#15803d',800:'#166534',900:'#14532d' },
                        stone:  { 50:'#fafaf9',100:'#f5f5f4',200:'#e7e5e4',300:'#d6d3d1',400:'#a8a29e',500:'#78716c',600:'#57534e',700:'#44403c',800:'#292524',900:'#1c1917' },
                    },
                    fontFamily: { display: ['Georgia','serif'] }
                }
            }
        }
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.8/dist/cdn.min.js"></script>
    <style>
        [x-cloak] { display: none !important; }
        html { scroll-behavior: smooth; }
        .lang-bar a { opacity: .65; transition: opacity .15s; }
        .lang-bar a:hover, .lang-bar a.active { opacity: 1; }
    </style>
</head>
<body class="bg-stone-50 text-stone-800 font-sans">

    <!-- Jazyková lišta -->
    <div class="lang-bar fixed top-3 right-4 z-[60] flex items-center gap-2 bg-black/30 backdrop-blur-sm rounded-full px-3 py-1.5">
        <a href="#" title="Česky"   class="active"><img src="https://flagcdn.com/w20/cz.png" width="20" height="14" alt="CZ" class="rounded-sm" /></a>
        <a href="#" title="English"><img src="https://flagcdn.com/w20/gb.png" width="20" height="14" alt="EN" class="rounded-sm" /></a>
        <a href="#" title="Deutsch"><img src="https://flagcdn.com/w20/de.png" width="20" height="14" alt="DE" class="rounded-sm" /></a>
    </div>

    @RenderBody()

    <!-- AI Chatbot widget -->
    <div x-data="karlChat()" x-cloak class="fixed bottom-6 right-6 z-50 flex flex-col items-end gap-3">
        <!-- Chat okno -->
        <div x-show="open"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 translate-y-4"
             x-transition:enter-end="opacity-100 translate-y-0"
             class="w-80 sm:w-96 bg-white rounded-2xl shadow-2xl border border-stone-200 flex flex-col overflow-hidden"
             style="height:420px">
            <div class="bg-forest-800 text-white px-5 py-4 flex items-center justify-between">
                <div>
                    <p class="font-semibold text-sm">Hotel Karl – Asistent</p>
                    <p class="text-xs text-forest-200">Zeptejte se na cokoli</p>
                </div>
                <button x-on:click="open=false" class="text-forest-200 hover:text-white">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="flex-1 overflow-y-auto p-4 space-y-3" x-ref="msgbox">
                <template x-for="m in messages" :key="m.id">
                    <div :class="m.role==='user' ? 'flex justify-end' : 'flex justify-start'">
                        <div :class="m.role==='user'
                            ? 'bg-forest-700 text-white rounded-2xl rounded-tr-sm px-4 py-2.5 text-sm max-w-[80%]'
                            : 'bg-stone-100 text-stone-800 rounded-2xl rounded-tl-sm px-4 py-2.5 text-sm max-w-[85%]'"
                             x-text="m.text"></div>
                    </div>
                </template>
                <div x-show="loading" class="flex justify-start">
                    <div class="bg-stone-100 rounded-2xl rounded-tl-sm px-4 py-3">
                        <div class="flex gap-1">
                            <span class="w-2 h-2 bg-stone-400 rounded-full animate-bounce" style="animation-delay:0ms"></span>
                            <span class="w-2 h-2 bg-stone-400 rounded-full animate-bounce" style="animation-delay:150ms"></span>
                            <span class="w-2 h-2 bg-stone-400 rounded-full animate-bounce" style="animation-delay:300ms"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="border-t border-stone-100 p-3 flex gap-2">
                <input x-model="input" x-on:keydown.enter="send()"
                       type="text" placeholder="Napište dotaz…"
                       class="flex-1 text-sm border border-stone-200 rounded-xl px-3 py-2 focus:outline-none focus:border-forest-500" />
                <button x-on:click="send()" :disabled="loading || !input.trim()"
                        class="bg-forest-700 hover:bg-forest-600 disabled:opacity-40 text-white px-4 py-2 rounded-xl text-sm font-semibold transition-colors">
                    Odeslat
                </button>
            </div>
        </div>

        <!-- Tlačítko -->
        <button x-on:click="open=!open"
                class="w-14 h-14 bg-forest-700 hover:bg-forest-600 text-white rounded-full shadow-xl flex items-center justify-center transition-all hover:scale-105">
            <svg x-show="!open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-3 3v-3z"/></svg>
            <svg x-show="open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
    function karlChat() {
        return {
            open: false,
            input: '',
            loading: false,
            messages: [{ id: 0, role: 'assistant', text: 'Dobrý den! Jsem asistent Hotelu Karl. Mohu vám pomoci s informacemi o ubytování, cenách nebo aktivitách na Šumavě.' }],
            async send() {
                const msg = this.input.trim();
                if (!msg || this.loading) return;
                this.messages.push({ id: Date.now(), role: 'user', text: msg });
                this.input = '';
                this.loading = true;
                this.$nextTick(() => { this.$refs.msgbox.scrollTop = 9999; });
                try {
                    const r = await fetch('/api/chat', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ message: msg }) });
                    const d = await r.json();
                    this.messages.push({ id: Date.now() + 1, role: 'assistant', text: d.reply });
                } catch { this.messages.push({ id: Date.now() + 1, role: 'assistant', text: 'Omlouváme se, zkuste to prosím znovu.' }); }
                this.loading = false;
                this.$nextTick(() => { this.$refs.msgbox.scrollTop = 9999; });
            }
        };
    }
    </script>
</body>
</html>
